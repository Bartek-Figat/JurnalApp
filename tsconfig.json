{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node"],
    "target": "ES2022",
    "module": "ES2022",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "removeComments": true,
    "incremental": true,
    "resolveJsonModule": true
  }
}
